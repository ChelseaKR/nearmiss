        },
        "presentation_vintage": {
          "const": 2024
        },
        "raw_zip_sha256": {
          "const": "590c1bfc1ae2746163a7417100670680a4a0ca79a577771e3c7c6821eea5149f"
        },
        "raw_zip_size_bytes": {
          "const": 802100
        },
        "resolution": {
          "const": "1:20,000,000"
        }
