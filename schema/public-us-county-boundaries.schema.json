      "required": [
        "presentation_vintage",
        "distribution_url",
        "raw_zip_sha256",
        "raw_zip_size_bytes",
        "member_name",
        "member_sha256",
        "resolution",
        "conversion_version"
      ],
      "type": "object"
    },
    "state": {
      "additionalProperties": false,
      "properties": {
        "state_abbreviation": {
          "pattern": "^[A-Z]{2}$",
