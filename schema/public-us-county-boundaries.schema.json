{
  "$id": "https://nearmiss.dev/schema/public-us-county-boundaries.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "accounting": {
      "additionalProperties": false,
      "properties": {
        "coordinate_count": {
          "maximum": 500000,
          "minimum": 4,
          "type": "integer"
        },
        "feature_count": {
          "maximum": 300,
          "minimum": 1,
          "type": "integer"
        },
        "multipolygon_feature_count": {
          "maximum": 300,
          "minimum": 0,
          "type": "integer"
        },
        "polygon_feature_count": {
          "maximum": 300,
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "feature_count",
        "polygon_feature_count",
        "multipolygon_feature_count",
        "coordinate_count"
      ],
      "type": "object"
    },
    "artifact_type": {
      "const": "nearmiss.public.us_county_boundary_shard"
    },
    "features": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "geometry": {
            "oneOf": [
              {
                "additionalProperties": false,
                "properties": {
                  "coordinates": {
                    "items": {
                      "items": {
                        "items": false,
                        "maxItems": 2,
                        "minItems": 2,
                        "prefixItems": [
                          {
                            "maximum": 180,
                            "minimum": -180,
                            "type": "number"
                          },
                          {
                            "maximum": 90,
                            "minimum": -90,
                            "type": "number"
                          }
                        ],
                        "type": "array"
                      },
                      "minItems": 4,
                      "type": "array"
                    },
                    "minItems": 1,
                    "type": "array"
                  },
                  "type": {
                    "const": "Polygon"
                  }
                },
                "required": [
                  "type",
                  "coordinates"
                ],
                "type": "object"
              },
              {
                "additionalProperties": false,
                "properties": {
                  "coordinates": {
                    "items": {
                      "items": {
                        "items": {
                          "items": false,
                          "maxItems": 2,
                          "minItems": 2,
                          "prefixItems": [
                            {
                              "maximum": 180,
                              "minimum": -180,
                              "type": "number"
                            },
                            {
                              "maximum": 90,
                              "minimum": -90,
                              "type": "number"
                            }
                          ],
                          "type": "array"
                        },
                        "minItems": 4,
                        "type": "array"
                      },
