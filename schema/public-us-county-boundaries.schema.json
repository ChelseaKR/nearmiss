                    "const": "MultiPolygon"
                  }
                },
                "required": [
                  "type",
                  "coordinates"
                ],
                "type": "object"
              }
            ]
          },
          "id": {
            "pattern": "^[0-9]{5}$",
            "type": "string"
          },
          "properties": {
            "additionalProperties": false,
            "properties": {
              "county_fips": {
                "pattern": "^[0-9]{3}$",
                "type": "string"
              },
              "geoid": {
                "pattern": "^[0-9]{5}$",
                "type": "string"
              },
              "name": {
