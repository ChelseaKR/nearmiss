        "state_fips",
        "state_abbreviation",
        "state_name"
      ],
      "type": "object"
    },
    "visibility": {
      "const": "public"
    }
  },
  "required": [
    "schema_version",
    "artifact_type",
    "visibility",
    "state",
    "source",
    "accounting",
    "features"
  ],
  "title": "Public NearMiss state-sharded 2024 Census county-equivalent boundaries",
  "type": "object"
}
