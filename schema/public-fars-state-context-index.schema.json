{
  "$id": "https://nearmiss.dev/schema/public-fars-state-context-index.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_type": {
      "const": "nearmiss.public.fars_state_context_index"
    },
    "contract": {
      "const": {
        "algorithm_version": "state-involved-mode-v1",
        "artifact_schema_version": "1.0.0",
        "artifact_type": "nearmiss.public.fars_state_context",
        "contribution_unit": "distinct_crash_once_per_involved_mode",
        "dimension": "involved_mode",
        "effective_k": 10,
        "modes": [
          "motor_vehicle_occupant",
          "motorcyclist",
          "pedalcyclist",
          "pedestrian",
          "other_road_user",
          "unknown"
        ],
        "modes_non_additive": true,
        "state_count": 51
      }
    },
    "default_year": {
      "enum": [
        2020,
        2021,
        2022,
        2023,
        2024
      ],
      "type": "integer"
    },
    "releases": {
      "items": {
        "$ref": "#/$defs/release"
      },
      "maxItems": 5,
      "minItems": 1,
      "type": "array"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "visibility": {
      "const": "public"
    }
  },
  "required": [
    "artifact_type",
    "contract",
    "default_year",
    "releases",
    "schema_version",
    "visibility"
  ],
  "title": "Public NearMiss annual FARS state-context release index",
  "type": "object",
  "$defs": {
