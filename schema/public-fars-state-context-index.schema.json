      "additionalProperties": false,
      "properties": {
        "contract_revision": {
          "minimum": 1,
          "type": "integer"
        },
        "contract_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "crash_mapping_version": {
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "type": "string"
        },
        "person_mapping_version": {
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "type": "string"
        },
        "semantic_regime_id": {
          "minLength": 1,
          "type": "string"
        },
        "state_code_system": {
          "pattern": "^nhtsa_fars_state_20(20|21|22|23|24)$",
          "type": "string"
        }
      },
      "required": [
        "contract_revision",
        "contract_sha256",
        "crash_mapping_version",
        "person_mapping_version",
        "semantic_regime_id",
        "state_code_system"
